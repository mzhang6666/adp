{
  "input_schema": {
    "type": "object",
    "properties": {
      "query": {
        "type": "string",
        "description": "用户查询问题或关键词"
      },
      "search_scope": {
        "type": "object",
        "description": "检索范围配置",
        "additionalProperties": true
      },
      "max_concepts": {
        "type": "integer",
        "description": "最大概念数量"
      }
    },
    "required": ["query"]
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "concepts": {
        "type": "array",
        "description": "相关概念列表",
        "items": {
          "type": "object",
          "properties": {
            "concept_type": {
              "type": "string",
              "description": "概念类型"
            },
            "concept_id": {
              "type": "string",
              "description": "概念ID"
            },
            "concept_name": {
              "type": "string",
              "description": "概念名称"
            },
            "concept_detail": {
              "description": "概念详情",
              "additionalProperties": true
            }
          }
        }
      }
    }
  }
}
